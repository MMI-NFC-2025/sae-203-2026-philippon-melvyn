---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/Hero.astro";
import PictureHero from "../../components/Picture.astro";
import SceneCard from "../../components/SceneCard.astro";

import heroImage from "../../assets/img/hero_scene.avif";

import { getScenes } from "../../js/backend.mjs";

const seoTitle = "Scènes | Les Rives du Territoire";
const pageTitle = "Les scènes";
const subTitle = "Découvrez les différents lieux du festival";
const description =
    "Découvrez toutes les scènes du festival Les Rives du Territoire.";

const scenes = await getScenes();
---

<Layout title={seoTitle} description={description}>
    <Hero title={pageTitle} subTitle={subTitle}>
        <PictureHero slot="image" src={heroImage} alt="Scènes du festival" />

    </Hero>

    <section class="bg-white py-16 lg:py-24">
        <div class="grille">
            <div class="col-span-4 lg:col-span-12">
                <div class="lg:grid lg:grid-cols-12 lg:gap-8">
                    <div class="lg:col-span-3">

                        <p class="mt-3 text-text-muted">
                            Explorez les lieux qui accueillent les concerts et
                            événements du festival.
                        </p>
                    </div>

                    <div class="mt-8 lg:col-span-9 lg:mt-0">
                        {
                            scenes.length > 0 ? (
                                <div class="grid gap-6 lg:grid-cols-2">
                                    {scenes.map((scene) => (
                                        <SceneCard scene={scene} />
                                    ))}
                                </div>
                            ) : (
                                <div class="rounded-3xl border border-blue-300/20 bg-white p-6 shadow-sm">
                                    <p class="text-text-muted">
                                        Aucune scène n'est disponible pour le
                                        moment.
                                    </p>
                                </div>
                            )
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>
