---
import PictureHero from "../components/Picture.astro";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import imgHero from "../assets/img/hero_apropos2.avif";

const seotitle = "Programme | Festival Les Rives du Territoire";
const pagetitle = "Programme ";
const subTitle = "Tous les concerts et représentations du festival";
const description =
    "Consultez le programme complet du festival Les Rives du Territoire à Belfort. Découvrez les artistes, les scènes et les horaires des concerts du 20 au 23 décembre 2026.";
---

<Layout title={seotitle} description={description}>
    <Hero title={pagetitle} subTitle={subTitle}>
        <PictureHero
            slot="image"
            src={imgHero}
            alt="Violoncelles"
            layout="full-width"
            pictureAttributes={{ class: "absolute inset-0 object-cover" }}
        />
    </Hero>
</Layout>
