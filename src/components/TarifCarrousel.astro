---
const tarifs = [
    {
        title: "Pass 1 jour",
        price: "35€",
        text: "Accès à une journée complète du festival et à toutes les scènes ouvertes ce jour-là.",
    },
    {
        title: "Pass 2 jours",
        price: "60€",
        text: "Idéal pour profiter du week-end et découvrir une grande partie de la programmation.",
    },
    {
        title: "Pass 4 jours",
        price: "120€",
        text: "L’expérience complète pour vivre le festival dans son intégralité, du 20 au 23 décembre.",
    },
];

const carouselId = `tarifs-${Math.random().toString(36).slice(2, 9)}`;
---

<div id={carouselId} class="relative">
    <div class="overflow-hidden lg:hidden">
        <div
            class="carousel-track flex transition-transform duration-500 ease-in-out"
            style="transform: translateX(0%)"
        >
            {
                tarifs.map((tarif) => (
                    <div class="min-w-full px-2">
                        <article class="flex h-60 flex-col justify-between rounded-3xl bg-blue-300/40 p-6 shadow-sm">
                            <div>
                                <h3 class="text-xl text-text">{tarif.title}</h3>
                                <p class="mt-3 text-4xl font-semibold text-blue-500">
                                    {tarif.price}
                                </p>
                            </div>

                            <p class="mt-4 text-text-muted">
                                {tarif.text}
                            </p>
                        </article>
                    </div>
                ))
            }
        </div>
    </div>

    <div class="hidden lg:grid lg:grid-cols-3 lg:gap-4">
        {
            tarifs.map((tarif) => (
                <article class="flex h-60 flex-col justify-between rounded-3xl bg-blue-300/40 p-6 shadow-sm">
                    <div>
                        <h3 class="text-xl text-text">{tarif.title}</h3>
                        <p class="mt-3 text-4xl font-semibold text-blue-500">
                            {tarif.price}
                        </p>
                    </div>

                    <p class="mt-4 text-text-muted">
                        {tarif.text}
                    </p>
                </article>
            ))
        }
    </div>

    <div class="mt-5 flex items-center justify-center gap-4 lg:hidden">
        <button
            type="button"
            class="carousel-prev rounded-full bg-blue-500 px-4 py-2 text-sm font-semibold text-white transition hover:bg-coral-400"
            aria-label="Tarif précédent"
        >
            ←
        </button>

        <div class="flex items-center justify-center gap-2">
            {
                tarifs.map((_, index) => (
                    <button
                        type="button"
                        class:list={[
                            "carousel-dot h-3 w-3 rounded-full transition",
                            index === 0 ? "bg-blue-500" : "bg-blue-300/40",
                        ]}
                        aria-label={`Aller au tarif ${index + 1}`}
                        data-index={index}
                    />
                ))
            }
        </div>

        <button
            type="button"
            class="carousel-next rounded-full bg-blue-500 px-4 py-2 text-sm font-semibold text-white transition hover:bg-coral-400"
            aria-label="Tarif suivant"
        >
            →
        </button>
    </div>
</div>

<script define:vars={{ carouselId }}>
    const root = document.getElementById(carouselId);

    if (root) {
        const track = root.querySelector(".carousel-track");
        const dots = [...root.querySelectorAll(".carousel-dot")];
        const prevBtn = root.querySelector(".carousel-prev");
        const nextBtn = root.querySelector(".carousel-next");
        const total = dots.length;
        let currentIndex = 0;

        const updateCarousel = () => {
            if (!track) return;

            track.style.transform = `translateX(-${currentIndex * 100}%)`;

            dots.forEach((dot, index) => {
                dot.classList.toggle("bg-blue-500", index === currentIndex);
                dot.classList.toggle("bg-blue-300/40", index !== currentIndex);
            });
        };

        prevBtn?.addEventListener("click", () => {
            currentIndex = currentIndex === 0 ? total - 1 : currentIndex - 1;
            updateCarousel();
        });

        nextBtn?.addEventListener("click", () => {
            currentIndex = currentIndex === total - 1 ? 0 : currentIndex + 1;
            updateCarousel();
        });

        dots.forEach((dot) => {
            dot.addEventListener("click", () => {
                currentIndex = Number(dot.dataset.index);
                updateCarousel();
            });
        });

        updateCarousel();
    }
</script>