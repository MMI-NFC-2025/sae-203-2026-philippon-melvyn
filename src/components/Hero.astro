---
const { title, subTitle } = Astro.props;
---

<section class="relative overflow-hidden bg-text">
    <div class="absolute inset-0">
        <slot name="image" />
        <div class="absolute inset-0 bg-black/35"></div>
        <div
            class="absolute inset-0 bg-linear-to-r from-black/45 via-black/20 to-transparent"
        >
        </div>
    </div>

    <div class="relative min-h-[78vh] lg:min-h-[82vh]">
        <div
            class="grille min-h-[78vh] items-end pt-24 pb-8 lg:min-h-[82vh] lg:pt-28 lg:pb-12"
        >
            <div
                class="relative z-10 col-span-4 text-white lg:col-span-7 lg:pb-8"
            >
                <div class="mb-8 lg:mb-12">
                    <slot name="cta" />
                </div>

                {
                    subTitle && (
                        <p class="mb-4 max-w-3xl text-sm uppercase tracking-[0.25em] text-white/80 lg:text-base">
                            {subTitle}
                        </p>
                    )
                }

                <h1 class="max-w-4xl text-white drop-shadow-lg">
                    {title}
                </h1>
            </div>
        </div>

        
    </div>
</section>
