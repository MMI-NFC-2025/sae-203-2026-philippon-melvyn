---
import "../styles/global.css";

import "@fontsource-variable/inter";
import "@fontsource-variable/playfair-display";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getPBFromRequest } from "../js/backend.mjs";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Les rives du territoire",
	description = "Festival de musique du 20 au 23 décembre 2026 à Belfort.",
} = Astro.props;

const siteName = "Les rives du territoire";
const titleHead =
	Astro.url.pathname === "/" ? siteName : `${title} — ${siteName}`;

const pb = getPBFromRequest(Astro.request);
const isAuthenticated = pb.authStore.isValid;
const currentUser = isAuthenticated ? pb.authStore.model : null;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />

		<title>{titleHead}</title>
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/apple-touch-icon.png"
		/>
		<link rel="manifest" href="/site.webmanifest" />

		<meta name="theme-color" content="#3A8CE9" />
	</head>

	<body class="min-h-screen flex flex-col bg-background text-text font-sans">
		<Header isAuthenticated={isAuthenticated} user={currentUser} />

		<main id="main-content" class="flex-1">
			<slot />
		</main>

		<Footer />
	</body>
</html>
