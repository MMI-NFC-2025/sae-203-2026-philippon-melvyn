---
import Layout from "../../layouts/Layout.astro";
import ImagePB from "../../components/ImagePB.astro";
import {
    getSceneById,
    getArtistesBySceneId,
    buildFileURL,
} from "../../js/backend.mjs";

const { id } = Astro.params;

const scene = await getSceneById(id);
const artistes = await getArtistesBySceneId(id);

if (!scene) {
    return Astro.redirect("/scenes");
}

const seoTitle = `${scene.nom} | Scènes | Les Rives du Territoire`;
const pageTitle = scene.nom;
const description =
    scene.description ||
    `Découvrez la scène ${scene.nom} du festival Les Rives du Territoire.`;

const couvertureUrl = scene.converture
    ? buildFileURL("Scene", scene.id, scene.converture)
    : null;

const formatDayLabel = (dateString: string): string => {
    if (!dateString) return "";
    return new Date(dateString).toLocaleDateString("fr-FR", {
        weekday: "long",
        day: "numeric",
        month: "long",
    });
};

const formatHourLabel = (dateString: string): string => {
    if (!dateString) return "";
    return new Date(dateString).toLocaleTimeString("fr-FR", {
        hour: "2-digit",
        minute: "2-digit",
    });
};

const groupedByDay = artistes.reduce(
    (acc: Record<string, any>, artiste: any) => {
        const key = artiste.date_de_presentation
            ? new Date(artiste.date_de_presentation).toLocaleDateString(
                  "fr-FR",
                  {
                      year: "numeric",
                      month: "2-digit",
                      day: "2-digit",
                  },
              )
            : "unknown";

        if (!acc[key]) acc[key] = [];
        acc[key].push(artiste);
        return acc;
    },
    {} as Record<string, any>,
);

const days = Object.entries(groupedByDay);
---

<Layout title={seoTitle} description={description}>
    <section class="bg-white pb-16 lg:pb-24">
        <div class="grille pt-12 lg:pt-16">
            <div class="col-span-4 lg:col-span-12">
                <div class="lg:grid lg:grid-cols-12 lg:gap-8">
                    <div class="lg:col-span-5">
                        <div class="overflow-hidden rounded-3xl shadow-sm">
                            {
                                couvertureUrl ? (
                                    <ImagePB
                                        src={couvertureUrl}
                                        alt={scene.nom}
                                        thumb="1024x680"
                                        classImg="h-72 w-full object-cover lg:h-112"
                                    />
                                ) : (
                                    <div class="h-72 w-full bg-linear-to-br from-fuchsia-400 to-blue-500 lg:h-112" />
                                )
                            }
                        </div>
                    </div>

                    <div class="mt-8 lg:col-span-7 lg:mt-0">
                        <h1 class="text-text">{pageTitle}</h1>

                        <p class="mt-4 text-lg text-text-muted">
                            {scene.description}
                        </p>

                        <div class="mt-8 grid grid-cols-2 gap-4 lg:grid-cols-3">
                            <div
                                class="rounded-2xl border border-blue-300/30 bg-white p-4 shadow-sm"
                            >
                                <p class="text-sm text-text-muted">Capacité</p>
                                <p
                                    class="mt-2 text-2xl font-semibold text-blue-500"
                                >
                                    {scene.capacite || "—"}
                                </p>
                            </div>

                            <div
                                class="rounded-2xl border border-blue-300/30 bg-white p-4 shadow-sm"
                            >
                                <p class="text-sm text-text-muted">
                                    Localisation
                                </p>
                                <p class="mt-2 text-lg font-semibold text-text">
                                    {scene.localisation || "—"}
                                </p>
                            </div>

                            <div
                                class="rounded-2xl border border-blue-300/30 bg-white p-4 shadow-sm"
                            >
                                <p class="text-sm text-text-muted">Artistes</p>
                                <p
                                    class="mt-2 text-2xl font-semibold text-blue-500"
                                >
                                    {artistes.length}
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-span-4 mt-14 lg:col-span-12">
                <div class="lg:grid lg:grid-cols-12 lg:gap-8">
                    <div class="lg:col-span-3">
                        <h2 class="text-text">Programmation</h2>
                        <p class="mt-3 text-text-muted">
                            Les artistes programmés sur cette scène.
                        </p>
                    </div>

                    <div class="mt-8 lg:col-span-9 lg:mt-0">
                        {
                            days.length > 0 ? (
                                <div class="space-y-6">
                                    {days.map(([_, items]) => (
                                        <section class="rounded-3xl bg-blue-300/10 p-5 shadow-sm">
                                            <div class="mb-4 border-b border-blue-300/30 pb-3">
                                                <h3 class="text-xl text-text">
                                                    {formatDayLabel(
                                                        (items as any[])[0]
                                                            ?.date_de_presentation,
                                                    )}
                                                </h3>
                                            </div>

                                            <div class="space-y-3">
                                                {(items as any[]).map(
                                                    (artiste: any) => (
                                                        <a
                                                            href={`/artistes/${artiste.id}`}
                                                            class="block rounded-2xl bg-white p-4 no-underline shadow-sm transition duration-300 hover:-translate-y-1 hover:border-coral-400"
                                                        >
                                                            <div class="flex items-center justify-between gap-4">
                                                                <div>
                                                                    <h4 class="text-lg text-text">
                                                                        {
                                                                            artiste.nom
                                                                        }
                                                                    </h4>
                                                                    <p class="mt-1 text-text-muted">
                                                                        {formatHourLabel(
                                                                            artiste.date_de_presentation,
                                                                        )}
                                                                    </p>
                                                                </div>

                                                                <span class="rounded-full bg-blue-300/25 px-3 py-1 text-sm text-blue-500">
                                                                    Voir
                                                                </span>
                                                            </div>
                                                        </a>
                                                    ),
                                                )}
                                            </div>
                                        </section>
                                    ))}
                                </div>
                            ) : (
                                <div class="rounded-3xl border border-blue-300/20 bg-white p-6 shadow-sm">
                                    <p class="text-text-muted">
                                        Aucun artiste n’est encore programmé sur
                                        cette scène.
                                    </p>
                                </div>
                            )
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>
