---
const { images = [] } = Astro.props as {
    images?: Array<{ src: string; alt: string }>;
};

const carouselId = `carousel-${Math.random().toString(36).slice(2, 9)}`;
---

<div id={carouselId} class="relative overflow-hidden">
    <div
        class="carousel-track flex transition-transform duration-500 ease-in-out"
        style="transform: translateX(0%)"
    >
        {
            images.map((image) => (
                <div class="min-w-full">
                    <img
                        src={image.src}
                        alt={image.alt}
                        class="h-72 w-full rounded-3xl object-cover lg:h-128"
                    />
                </div>
            ))
        }
    </div>

    {
        images.length > 1 && (
            <>
                <button
                    type="button"
                    class="carousel-prev absolute left-4 top-1/2 z-10 -translate-y-1/2 rounded-full bg-white/90 px-4 py-2 text-sm font-semibold text-text shadow transition hover:bg-coral-400 hover:text-white"
                    aria-label="Image précédente"
                >
                    ←
                </button>

                <button
                    type="button"
                    class="carousel-next absolute right-4 top-1/2 z-10 -translate-y-1/2 rounded-full bg-white/90 px-4 py-2 text-sm font-semibold text-text shadow transition hover:bg-coral-400 hover:text-white"
                    aria-label="Image suivante"
                >
                    →
                </button>

                <div class="absolute bottom-4 left-1/2 z-10 flex -translate-x-1/2 gap-2">
                    {images.map((_, index) => (
                        <button
                            type="button"
                            class:list={[
                                "carousel-dot h-3 w-3 rounded-full transition",
                                index === 0 ? "bg-blue-500" : "bg-white/70",
                            ]}
                            aria-label={`Aller à l'image ${index + 1}`}
                            data-index={index}
                        />
                    ))}
                </div>
            </>
        )
    }
</div>

<script define:vars={{ carouselId }}>
    const root = document.getElementById(carouselId);

    if (root) {
        const track = root.querySelector(".carousel-track");
        const slides = [...root.querySelectorAll(".carousel-track > div")];
        const prevBtn = root.querySelector(".carousel-prev");
        const nextBtn = root.querySelector(".carousel-next");
        const dots = [...root.querySelectorAll(".carousel-dot")];

        let currentIndex = 0;
        const total = slides.length;

        const updateCarousel = () => {
            if (!track) return;

            track.style.transform = `translateX(-${currentIndex * 100}%)`;

            dots.forEach((dot, index) => {
                dot.classList.toggle("bg-blue-500", index === currentIndex);
                dot.classList.toggle("bg-white/70", index !== currentIndex);
            });
        };

        prevBtn?.addEventListener("click", () => {
            currentIndex = currentIndex === 0 ? total - 1 : currentIndex - 1;
            updateCarousel();
        });

        nextBtn?.addEventListener("click", () => {
            currentIndex = currentIndex === total - 1 ? 0 : currentIndex + 1;
            updateCarousel();
        });

        dots.forEach((dot) => {
            dot.addEventListener("click", () => {
                currentIndex = Number(dot.dataset.index);
                updateCarousel();
            });
        });

        updateCarousel();
    }
</script>
