---
import Logo from "../assets/icones/Logo.svg";

import Instagram from "../assets/icones/icon_instagram.svg";
import Discord from "../assets/icones/icon_discord.svg";
import Facebook from "../assets/icones/icon_facebook.svg";
import Linkedin from "../assets/icones/icon_linkedin.svg";
---

<footer class="bg-blue-500 text-white">
    <div
        class="mx-auto grid max-w-7xl gap-10 px-6 py-14 lg:grid-cols-12 lg:gap-8"
    >
        <div class="lg:col-span-5">
            <a href="/" aria-label="Accueil">
                <Logo class="h-14 w-auto brightness-0 invert" />
            </a>

            <p class="mt-5 max-w-md text-sm leading-relaxed text-white">
                Les Rives du Territoire est un festival de musique organisé à
                Belfort du 20 au 23 décembre 2026. Quatre jours de concerts, de
                découvertes musicales et d’expériences uniques autour de la
                scène actuelle.
            </p>
        </div>

        <nav class="lg:col-span-3" aria-label="Navigation du pied de page">
            <h3 class="mb-4 font-serif text-lg text-white">Navigation</h3>

            <ul class="space-y-3 p-0 text-sm">
                <li>
                    <a
                        href="/"
                        class="no-underline text-white transition hover:text-orange-300"
                    >
                        Accueil
                    </a>
                </li>
                <li>
                    <a
                        href="/festival"
                        class="no-underline text-white transition hover:text-orange-300"
                    >
                        Le festival
                    </a>
                </li>
                <li>
                    <a
                        href="/programme"
                        class="no-underline text-white transition hover:text-orange-300"
                    >
                        Programme
                    </a>
                </li>
                <li>
                    <a
                        href="/infos-pratiques"
                        class="no-underline text-white transition hover:text-orange-300"
                    >
                        Infos pratiques
                    </a>
                </li>
                <li>
                    <a
                        href="/contact"
                        class="no-underline text-white transition hover:text-orange-300"
                    >
                        Contact
                    </a>
                </li>
            </ul>
        </nav>

        <div class="lg:col-span-4">
            <h3 class="mb-4 font-serif text-lg text-white">Suivez-nous</h3>

            <div class="flex gap-4">
                <a
                    href="#"
                    aria-label="Instagram"
                    class="flex h-10 w-10 items-center justify-center rounded-md bg-white/10 text-white transition hover:bg-white/20"
                >
                    <Instagram class="h-5 w-5" />
                </a>

                <a
                    href="#"
                    aria-label="Discord"
                    class="flex h-10 w-10 items-center justify-center rounded-md bg-white/10 text-white transition hover:bg-white/20"
                >
                    <Discord class="h-5 w-5" />
                </a>

                <a
                    href="#"
                    aria-label="Facebook"
                    class="flex h-10 w-10 items-center justify-center rounded-md bg-white/10 text-white transition hover:bg-white/20"
                >
                    <Facebook class="h-5 w-5" />
                </a>

                <a
                    href="#"
                    aria-label="LinkedIn"
                    class="flex h-10 w-10 items-center justify-center rounded-md bg-white/10 text-white transition hover:bg-white/20"
                >
                    <Linkedin class="h-5 w-5" />
                </a>
            </div>
        </div>
    </div>

    <div class="border-t border-white/20">
        <div
            class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-3 px-6 py-5 text-sm text-white lg:flex-row"
        >
            <p class="mb-0 text-white">© 2026 Les Rives du Territoire</p>
            <p class="mb-0 text-white">Festival de musique — Belfort</p>
        </div>
    </div>
</footer>
