---
import PictureHero from "../components/Picture.astro";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import imgHero from "../assets/img/hero_apropos2.avif";

const seotitle = "Contact | Festival Les Rives du Territoire";
const pagetitle = "Contact";
const subTitle = "Une question ? Contactez-nous";
const description =
    "Besoin d’informations sur le festival Les Rives du Territoire ? Contactez l’équipe d’organisation pour toute question concernant l’événement, les artistes ou les informations pratiques.";
---

<Layout title={seotitle} description={description}>
    <Hero title={pagetitle} subTitle={subTitle}>
        <PictureHero
            slot="image"
            src={imgHero}
            alt="Violoncelles"
            layout="full-width"
            pictureAttributes={{ class: "absolute inset-0 object-cover" }}
        />
    </Hero>
</Layout>
