---
import { buildFileURL } from "../js/backend.mjs";
import ImagePB from "./ImagePB.astro";

const { scene } = Astro.props;

const imageUrl = scene?.converture
    ? buildFileURL("Scene", scene.id, scene.converture)
    : null;

const description =
    scene?.description ||
    "Découvrez cette scène du festival Les Rives du Territoire.";
---

<a
    href={`/scenes/${scene.id}`}
    class="block rounded-3xl border border-blue-300/20 bg-white p-5 no-underline shadow-sm transition duration-300 hover:-translate-y-1 hover:border-coral-400"
>
    <div class="overflow-hidden rounded-3xl">
        {
            imageUrl ? (
                <ImagePB
                    src={imageUrl}
                    alt={scene.nom}
                    thumb="1024x680"
                    classImg="h-56 w-full object-cover"
                />
            ) : (
                <div class="h-56 w-full bg-linear-to-br from-fuchsia-400 to-blue-500" />
            )
        }
    </div>

    <h2 class="mt-5 text-2xl text-text">
        {scene.nom}
    </h2>

    <p class="mt-3 text-text-muted">
        {description}
    </p>
</a>
