---
import PictureHero from "../components/Picture.astro";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import imgHero from "../assets/img/hero_apropos2.avif";

const seotitle = "Le Festival | Les Rives du Territoire";
const pagetitle = "À propos";
const subTitle = "Découvrez l’histoire et l’esprit du festival";
const description =
    "Le festival Les Rives du Territoire se déroule à Belfort du 20 au 23 décembre 2026. Découvrez son histoire, ses valeurs et l’équipe qui organise cet événement musical.";
---

<Layout title={seotitle} description={description}>
    <Hero title={pagetitle} subTitle={subTitle}>
        <PictureHero
            slot="image"
            src={imgHero}
            alt="Violoncelles"
            layout="full-width"
            pictureAttributes={{ class: "absolute inset-0 object-cover" }}
        />
    </Hero>
</Layout>



