---
const { title, subTitle } = Astro.props;
---

<section class="relative overflow-hidden">
    <div class="absolute inset-0">
        <slot name="image" />
        <div class="absolute inset-0 bg-black/30"></div>
    </div>

    <div class="relative min-h-[80vh]">
        <div
            class="mx-auto grid min-h-[80vh] max-w-7xl items-end px-6 pt-24 lg:grid-cols-12 lg:pt-28"
        >
            
            <div class="relative z-10 pb-10 text-white lg:col-span-7">
                <div class="mb-8 lg:mb-12">
                    <slot name="cta" />
                </div>

                {
                    subTitle && (
                        <p class="mb-4 text-sm uppercase tracking-[0.25em] text-white/80">
                            {subTitle}
                        </p>
                    )
                }

                <h1 class="max-w-3xl text-white drop-shadow-lg">
                    {title}
                </h1>
            </div>
        </div>

        <div
            class="pointer-events-none absolute inset-y-0 right-0 z-20 flex items-end"
        >
            <div
                class="pointer-events-auto w-full bg-white p-8 shadow-2xl sm:max-w-md lg:w-lg lg:min-h-[25vh] lg:p-10"
            >
                <slot name="chapo" />
            </div>
        </div>
    </div>
</section>
