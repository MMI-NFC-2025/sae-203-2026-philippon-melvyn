---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import PictureHero from "../components/Picture.astro";
import Button from "../components/Button.astro";

import imgHero from "../assets/img/hero_apropos2.avif";

import { getArtistesByDate } from "../js/backend.mjs";

const seoTitle = "Accueil | Festival Les Rives du Territoire";
const pageTitle = "Festival Les Rives du Territoire";
const subTitle = "Festival de musique du 20 au 23 décembre 2026 à Belfort";
const description =
	"Les Rives du Territoire est un festival de musique organisé à Belfort du 20 au 23 décembre 2026 avec des artistes sur plusieurs scènes.";

const artistes = await getArtistesByDate();
const artistesAccueil = artistes.slice(0, 4);
const programmeAccueil = artistes.slice(0, 4);

const infos = [
	{
		title: "Lieu",
		text: "Centre-ville de Belfort\nAccès facile en transport",
	},
	{
		title: "Billetterie",
		text: "Pass 4 jours : 120€\nBillet journée : 35€",
	},
	{
		title: "Hébergement",
		text: "Hôtels partenaires",
	},
	{
		title: "Restauration",
		text: "Food trucks variés\nBars et buvettes",
	},
];

const partenaires = [
	"PARTENAIRE 1",
	"PARTENAIRE 2",
	"PARTENAIRE 3",
	"PARTENAIRE 4",
];

function formatDateFR(dateString: string) {
	if (!dateString) return "";
	const date = new Date(dateString);

	return date.toLocaleDateString("fr-FR", {
		weekday: "long",
		day: "2-digit",
		month: "short",
	});
}

function getGenreLabel(genre: string | string[]) {
	if (!genre) return "";
	if (Array.isArray(genre)) return genre.join(" • ");
	return genre;
}
---

<Layout title={seoTitle} description={description}>
	<Hero title={pageTitle} subTitle={subTitle}>
		<Button
			slot="cta"
			href="/programme"
			text="Réserver mes places"
			variant="primary"
		/>

		<PictureHero slot="image" src={imgHero} alt="Ambiance du festival" />
	</Hero>

	<section class="bg-white py-16 lg:py-24">
		<div class="grille">
			<div class="col-span-4 text-center lg:col-span-6 lg:col-start-4">
				<h2 class="text-text">Programme</h2>
				<p class="mt-3 text-text-muted">
					4 jours de musique exceptionnelle
				</p>
			</div>

			<div
				class="col-span-4 mt-10 grid gap-5 lg:col-span-10 lg:col-start-2 lg:grid-cols-2"
			>
				{
					programmeAccueil.map((artiste) => (
						<article class="rounded-3xl border border-blue-300/30 bg-blue-500 p-6 shadow-lg transition duration-300 hover:-translate-y-1 hover:bg-coral-400">
							<p class="text-base font-semibold text-white/85">
								{formatDateFR(artiste.date_de_presentation)}
							</p>

							<h3 class="mt-3 text-2xl text-white">
								{artiste.nom}
							</h3>

							<p class="mt-3 text-white/75">
								{artiste.description}
							</p>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="bg-white py-16 lg:py-24">
		<div class="grille">
			<div class="col-span-4 text-center lg:col-span-6 lg:col-start-4">
				<h2 class="text-text">Artistes</h2>
				<p class="mt-3 text-text-muted">
					Une programmation exceptionnelle
				</p>
			</div>

			<div
				class="col-span-4 mt-10 grid grid-cols-2 gap-5 lg:col-span-10 lg:col-start-2 lg:grid-cols-4"
			>
				{
					artistesAccueil.map((artiste, index) => (
						<article class="text-center">
							<a href="/Artistes" class="block no-underline">
								<div
									class:list={[
										"aspect-square rounded-3xl shadow-lg transition duration-300 hover:-translate-y-1",
										index === 0 &&
											"bg-linear-to-br from-fuchsia-400 to-pink-500",
										index === 1 &&
											"bg-linear-to-br from-blue-400 to-violet-500",
										index === 2 &&
											"bg-linear-to-br from-emerald-400 to-blue-500",
										index === 3 &&
											"bg-linear-to-br from-amber-400 to-red-500",
									]}
								/>

								<h3 class="mt-4 text-xl text-text">
									{artiste.nom}
								</h3>
								<p class="mt-1 text-text-muted">
									{getGenreLabel(artiste.genre_musical)}
								</p>
							</a>
						</article>
					))
				}
			</div>

			<div class="col-span-4 mt-10 flex justify-center">
				<Button
					href="/Artistes"
					text="Voir tous les artistes"
					variant="outline"
				/>
			</div>
		</div>
	</section>

	<section class="bg-white py-16 lg:py-24">
		<div class="grille">
			<div class="col-span-4 text-center lg:col-span-6 lg:col-start-4">
				<h2 class="text-text">Infos pratiques</h2>
				<p class="mt-3 text-text-muted">Tout ce qu'il faut savoir</p>
			</div>

			<div
				class="col-span-4 mt-10 grid gap-5 lg:col-span-10 lg:col-start-2 lg:grid-cols-2"
			>
				{
					infos.map((info) => (
						<article class="rounded-3xl border border-blue-300/30 bg-white p-6 shadow-md transition duration-300 hover:-translate-y-1 hover:border-coral-400">
							<h3 class="text-2xl text-text">{info.title}</h3>
							<p class="mt-3 whitespace-pre-line text-text-muted">
								{info.text}
							</p>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="bg-white py-16 lg:py-24">
		<div class="grille">
			<div class="col-span-4 text-center lg:col-span-6 lg:col-start-4">
				<h2 class="text-text">À propos</h2>
				<p class="mt-3 text-text-muted">L'esprit du festival</p>
			</div>

			<div class="col-span-4 mt-10 lg:col-span-8 lg:col-start-3">
				<div class="space-y-6 text-center lg:text-left">
					<p class="text-lg leading-relaxed text-text">
						Depuis 2022, notre festival rassemble les amoureux de
						musique dans une atmosphère unique et conviviale.
					</p>

					<p class="text-lg leading-relaxed text-text-muted">
						Découvrez une programmation variée mêlant têtes
						d'affiche internationales et talents émergents, dans un
						cadre exceptionnel au cœur de Belfort.
					</p>
				</div>

				<div class="mt-10 grid grid-cols-3 gap-4 text-center">
					<div
						class="rounded-2xl border border-blue-300/40 bg-white p-4 shadow-sm"
					>
						<p class="text-4xl font-semibold text-blue-500">50K+</p>
						<p class="mt-2 text-sm text-text-muted">Festivaliers</p>
					</div>

					<div
						class="rounded-2xl border border-blue-300/40 bg-white p-4 shadow-sm"
					>
						<p class="text-4xl font-semibold text-blue-500">100+</p>
						<p class="mt-2 text-sm text-text-muted">Artistes</p>
					</div>

					<div
						class="rounded-2xl border border-blue-300/40 bg-white p-4 shadow-sm"
					>
						<p class="text-4xl font-semibold text-blue-500">4</p>
						<p class="mt-2 text-sm text-text-muted">Scènes</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="bg-white py-16 lg:py-24">
		<div class="grille">
			<div class="col-span-4 text-center lg:col-span-6 lg:col-start-4">
				<h2 class="text-text">Nos partenaires</h2>
			</div>

			<div
				class="col-span-4 mt-10 grid grid-cols-2 gap-4 lg:col-span-10 lg:col-start-2 lg:grid-cols-4"
			>
				{
					partenaires.map((partenaire) => (
						<div class="rounded-2xl border border-blue-300/30 bg-white p-6 text-left text-xl font-semibold text-text shadow-sm transition duration-300 hover:-translate-y-1 hover:border-coral-400">
							{partenaire}
						</div>
					))
				}
			</div>
		</div>
	</section>
</Layout>
