---
const { artiste } = Astro.props;

const genres = Array.isArray(artiste.genre_musical)
    ? artiste.genre_musical
    : artiste.genre_musical
      ? [artiste.genre_musical]
      : [];

const sceneName = artiste.expand?.production?.nom || "Scène non renseignée";

const dateObj = artiste.date_de_presentation
    ? new Date(artiste.date_de_presentation)
    : null;

const dateLabel = dateObj
    ? dateObj.toLocaleDateString("fr-FR", {
          day: "numeric",
          month: "long",
          year: "numeric",
      })
    : "";

const hourLabel = dateObj
    ? dateObj.toLocaleTimeString("fr-FR", {
          hour: "2-digit",
          minute: "2-digit",
      })
    : "";
---

<a
    href={`/artistes/${artiste.id}`}
    class="block rounded-[1.6rem] border border-blue-300/20 bg-white p-5 no-underline shadow-sm transition hover:-translate-y-1 hover:border-coral-400"
>
    <div class="lg:grid lg:grid-cols-12 lg:items-center lg:gap-6">
        <div class="lg:col-span-3">
            {
                hourLabel && (
                    <p class="text-3xl font-semibold text-blue-500 lg:text-4xl">
                        {hourLabel}
                    </p>
                )
            }

            {
                dateLabel && (
                    <p class="mt-1 text-sm font-medium text-text-muted">
                        {dateLabel}
                    </p>
                )
            }
        </div>

        <div class="mt-4 lg:col-span-6 lg:mt-0">
            <h2 class="text-2xl text-text">
                {artiste.nom}
            </h2>

            <div class="mt-3 flex flex-wrap gap-2">
                {
                    (genres as string[])
                        .slice(0, 3)
                        .map((genre: string) => (
                            <span class="rounded-full bg-blue-300/25 px-3 py-1 text-sm text-blue-500">
                                {genre}
                            </span>
                        ))
                }
            </div>
        </div>

        <div class="mt-4 lg:col-span-3 lg:mt-0">
            <p class="font-semibold text-text">
                {sceneName}
            </p>
        </div>
    </div>
</a>
